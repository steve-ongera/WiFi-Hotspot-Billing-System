# =============================================================================
# WifiBill — Backend Environment Variables
# Copy this file to backend/.env and fill in your real values.
# NEVER commit the real .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
SECRET_KEY=wifibill-super-secret-key-change-this-in-production-2025!@#$
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# -----------------------------------------------------------------------------
# PostgreSQL Database
# Leave DB_HOST blank to fall back to SQLite in development
# -----------------------------------------------------------------------------
DB_NAME=wifibill_db
DB_USER=wifibill_user
DB_PASSWORD=wifibill_pass_2025
DB_HOST=localhost
DB_PORT=5432
# DB_SSLMODE=prefer   # uncomment in production

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# JWT Tokens
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# M-Pesa Daraja API  (Safaricom Developer Portal)
# Sandbox: https://developer.safaricom.co.ke
# -----------------------------------------------------------------------------
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_sandbox_consumer_key_here
MPESA_CONSUMER_SECRET=your_sandbox_consumer_secret_here

# Sandbox shortcode (use your own paybill in production)
MPESA_SHORTCODE=174379

# Lipa Na M-Pesa passkey (from Daraja portal)
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Callback URL — must be HTTPS in production; use ngrok for local dev
# ngrok command: ngrok http 8000
MPESA_CALLBACK_URL=https://abc123.ngrok.io/api/payments/mpesa/callback/

MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# -----------------------------------------------------------------------------
# MikroTik RouterOS API
# -----------------------------------------------------------------------------
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USERNAME=django-api
MIKROTIK_PASSWORD=StrongMikroTikPassword123

HOTSPOT_DEFAULT_PROFILE=default
HOTSPOT_SERVER_NAME=wifibill-hotspot

# -----------------------------------------------------------------------------
# Africa's Talking SMS  (optional — for payment confirmation SMS)
# https://account.africastalking.com
# -----------------------------------------------------------------------------
AT_USERNAME=sandbox
AT_API_KEY=atsk_your_africas_talking_api_key_here

# -----------------------------------------------------------------------------
# Email  (optional — Gmail example)
# Use an App Password, not your real Gmail password
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=yourname@gmail.com
EMAIL_HOST_PASSWORD=xxxx_xxxx_xxxx_xxxx
DEFAULT_FROM_EMAIL=WifiBill <noreply@wifibill.co.ke>

# -----------------------------------------------------------------------------
# CORS (production only — comma-separated)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------------------------------------
# Sentry error tracking (optional)
# https://sentry.io
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://your_key@o123456.ingest.sentry.io/project_id